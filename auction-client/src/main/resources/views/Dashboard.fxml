<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F5F5F7; -fx-font-family: '-apple-system', sans-serif;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DashboardController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" prefHeight="560.0" prefWidth="760.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 5);">
            <children>

                <Label text="Sàn Đấu Giá Trực Tuyến">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <TableView fx:id="tableItems" prefHeight="400.0" prefWidth="720.0" style="-fx-background-radius: 8; -fx-border-color: #E5E5EA; -fx-border-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="200.0" text="Tên sản phẩm" />
                        <TableColumn fx:id="colDesc" prefWidth="250.0" text="Mô tả" />
                        <TableColumn fx:id="colPrice" prefWidth="150.0" text="Giá hiện tại" />
                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Trạng thái" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <TextField fx:id="txtBidAmount" prefHeight="40.0" prefWidth="200.0" promptText="Nhập giá muốn đấu (VNĐ)" style="-fx-background-color: #F2F2F7; -fx-background-radius: 8; -fx-padding: 10;" />

                        <Button fx:id="btnBid" mnemonicParsing="false" onAction="#handlePlaceBid" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #007AFF; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;" text="Đặt Giá" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Button mnemonicParsing="false" onAction="#handleShowChart" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #34C759; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;" text="Xem Biểu Đồ Giá" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>