<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.shape.Circle?>

<StackPane stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DashboardController">
    <BorderPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #F5F5F5; -fx-font-family: '-apple-system', 'Segoe UI', sans-serif;">

    <top>
        <VBox style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #E0E0E0 transparent; -fx-border-width: 1;">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" style="-fx-padding: 0 30;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="1.0">
                            <Label text="e" textFill="#e53238"><font><Font name="System Bold" size="30.0"/></font></Label>
                            <Label text="b" textFill="#0064d2"><font><Font name="System Bold" size="30.0"/></font></Label>
                            <Label text="i" textFill="#f5af02"><font><Font name="System Bold" size="30.0"/></font></Label>
                            <Label text="d" textFill="#86b817"><font><Font name="System Bold" size="30.0"/></font></Label>
                        </HBox>
                        <Label text="Buyer Hub" textFill="#707070"><font><Font size="13.0"/></font></Label>
                        <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="600.0" spacing="10.0">
                            <children>
                                <TextField fx:id="txtSearch" prefHeight="35.0" promptText="Tìm kiếm sản phẩm..." style="-fx-border-color: #8f8f8f; -fx-border-radius: 4; -fx-background-color: transparent;" HBox.hgrow="ALWAYS" onAction="#handleSearch"/>
                                <Button style="-fx-background-color: #0654ba; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="Tìm kiếm" prefWidth="90.0" prefHeight="35.0" onAction="#handleSearch"/>
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <!-- Notification Bell -->
                                <StackPane alignment="CENTER" maxHeight="40.0" maxWidth="40.0" minHeight="40.0" minWidth="40.0" onMouseClicked="#handleShowNotifications" prefHeight="40.0" prefWidth="40.0" style="-fx-cursor: hand; -fx-background-radius: 50;" styleClass="icon-button">
                                    <children>
                                        <Label style="-fx-font-size: 18; -fx-text-fill: #707070;" text="🔔" />
                                        <Circle fill="#e62117" radius="4.0" stroke="WHITE" strokeWidth="1.0" translateX="7.0" translateY="-7.0" />
                                    </children>
                                </StackPane>
                                
                                <!-- Cart Icon area -->
                                <StackPane fx:id="cartIconContainer" alignment="CENTER" maxHeight="40.0" maxWidth="40.0" minHeight="40.0" minWidth="40.0" onMouseEntered="#handleShowMiniCart" onMouseExited="#handleHideMiniCart" prefHeight="40.0" prefWidth="40.0" style="-fx-cursor: hand; -fx-background-radius: 50;" styleClass="icon-button">
                                    <children>
                                        <Label style="-fx-font-size: 18; -fx-text-fill: #707070;" text="🛒" />
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <Label fx:id="lblGreeting" text="Xin chào, Bidder!" textFill="#191919">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <Button onAction="#handleLogout" styleClass="btn-logout" text="Đăng xuất" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <left>
        <VBox fx:id="sidebar" prefWidth="230.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-padding: 25 20; -fx-border-color: transparent #E0E0E0 transparent transparent;">
            <children>
                <Label fx:id="sideBrowse" styleClass="sidebar-label" text="Sản phẩm đang bán" textFill="#0654ba" onMouseClicked="#handleSideBrowse" style="-fx-font-weight: bold;"/>
                
                <Separator style="-fx-padding: 10 0;"/>
                
                <Label text="Cá nhân" style="-fx-font-weight: bold; -fx-font-size: 15;"/>
                <Label fx:id="sideHistory" styleClass="sidebar-label" text="Lịch sử đấu giá" textFill="#707070" onMouseClicked="#handleSideHistory" />
                <Label fx:id="sideWonItems" styleClass="sidebar-label" text="Sản phẩm đã thắng" textFill="#707070" onMouseClicked="#handleSideWonItems" />
                
                <Separator style="-fx-padding: 10 0;"/>

                <Label text="Danh mục" style="-fx-font-weight: bold; -fx-font-size: 15;"/>
                <Label fx:id="catAll" styleClass="sidebar-label" text="Tất cả sản phẩm" textFill="#707070" onMouseClicked="#handleCategoryAll" />
                <Label fx:id="catElectronics" styleClass="sidebar-label" text="Đồ điện tử" textFill="#707070" onMouseClicked="#handleCategoryElectronics" />
                <Label fx:id="catArt" styleClass="sidebar-label" text="Nghệ thuật" textFill="#707070" onMouseClicked="#handleCategoryArt" />
                <Label fx:id="catVehicle" styleClass="sidebar-label" text="Xe cộ" textFill="#707070" onMouseClicked="#handleCategoryVehicle" />
                <Label fx:id="catGeneral" styleClass="sidebar-label" text="Khác" textFill="#707070" onMouseClicked="#handleCategoryGeneral" />
            </children>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <!-- PAGE 1: Dàn sản phẩm đấu giá (Browse) -->
            <VBox fx:id="pageBrowse" spacing="20.0" style="-fx-padding: 20;">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <Label fx:id="lblCategoryTitle" text="Tất cả sản phẩm"><font><Font name="System Bold" size="22.0"/></font></Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-padding: 5 15; -fx-background-radius: 20; -fx-border-color: #E0E0E0; -fx-border-radius: 20;">
                            <Label text="Lọc theo:" textFill="#707070"><font><Font name="System Bold" size="14.0"/></font></Label>
                            <ComboBox fx:id="cboFilterCondition" promptText="Tình trạng" style="-fx-background-color: transparent; -fx-cursor: hand;" />
                            <Separator orientation="VERTICAL" />
                            <ComboBox fx:id="cboFilterPrice" promptText="Giá bán" style="-fx-background-color: transparent; -fx-cursor: hand;" />
                            <Separator orientation="VERTICAL" />
                            <ComboBox fx:id="cboFilterRating" promptText="Đánh giá" style="-fx-background-color: transparent; -fx-cursor: hand;" />
                        </HBox>
                    </HBox>
                    
                    <ScrollPane fx:id="scrollPaneBrowse" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <content>
                            <FlowPane fx:id="gridItems" hgap="20.0" vgap="20.0" style="-fx-padding: 5;" />
                        </content>
                    </ScrollPane>
                </children>
            </VBox>




            
            <!-- PAGE 4: Chi tiết sản phẩm (eBid Item Page) -->
            <ScrollPane fx:id="pageProductDetail" visible="false" managed="false" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <content>
                    <VBox spacing="30" style="-fx-padding: 40; -fx-background-color: white;">
                        <children>
                            <Hyperlink text="&lt; Back to search results" onAction="#handleBackToBrowse" style="-fx-text-fill: #0654ba; -fx-font-size: 14;" />
                    
                    <HBox spacing="50">
                        <children>
                            <!-- Left: Image Gallery -->
                            <VBox spacing="10" prefWidth="500">
                                <children>
                                    <Label fx:id="lblDetailImg" text="Image Not Available" style="-fx-background-color: #f7f7f7; -fx-alignment: center; -fx-font-size: 20; -fx-text-fill: #999; -fx-background-radius: 8;" prefWidth="500" prefHeight="500" />
                                </children>
                            </VBox>
                            
                            <!-- Right: Product Info -->
                            <VBox spacing="20" HBox.hgrow="ALWAYS" maxWidth="500">
                                <children>
                                    <Label fx:id="lblDetailName" style="-fx-font-weight: bold; -fx-font-size: 28;" wrapText="true" />
                                    <Separator />
                                    
                                    <VBox spacing="5">
                                        <Label text="Price:" textFill="#707070" style="-fx-font-size: 14;" />
                                        <HBox spacing="10" alignment="BOTTOM_LEFT">
                                            <Label fx:id="lblDetailPrice" style="-fx-font-weight: bold; -fx-font-size: 32;" />
                                            <Label text="VND" textFill="#707070" style="-fx-padding: 0 0 5 0;" />
                                        </HBox>
                                        <Label fx:id="lblBidStatus" text="Bạn chưa đặt giá" style="-fx-font-size: 14; -fx-padding: 5 15; -fx-background-radius: 15;" />
                                    </VBox>

                                    <HBox spacing="40">
                                        <VBox spacing="5">
                                            <Label text="Lượt đặt giá:" textFill="#707070" style="-fx-font-size: 14;" />
                                            <Label fx:id="lblDetailBidsCount" text="0 lượt" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #191919;" />
                                        </VBox>
                                        <VBox spacing="5">
                                            <Label text="Trạng thái:" textFill="#707070" style="-fx-font-size: 14;" />
                                            <Label fx:id="lblDetailStatus" text="Đang đấu giá" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #0654ba;" />
                                        </VBox>
                                    </HBox>

                                    <VBox spacing="5">
                                        <Label text="Thời gian còn lại:" textFill="#707070" style="-fx-font-size: 14;" />
                                        <Label fx:id="lblCountdown" text="--:--:--" style="-fx-font-weight: bold; -fx-font-size: 24; -fx-text-fill: #e62117;" />
                                    </VBox>
                                    
                                    <VBox spacing="20" style="-fx-background-color: #f7f7f7; -fx-padding: 25; -fx-background-radius: 12;">
                                        <children>
                                            <VBox spacing="10">
                                                <Label text="Đặt giá thủ công" style="-fx-font-weight: bold; -fx-font-size: 16;" />
                                                 <HBox spacing="10">
                                                     <children>
                                                         <TextField fx:id="txtBidAmount" prefHeight="50" promptText="Nhập mức giá..." style="-fx-background-radius: 25; -fx-padding: 0 20; -fx-font-size: 16;" HBox.hgrow="ALWAYS" />
                                                         <Button text="Đặt giá" onAction="#handlePlaceBid" style="-fx-background-color: #0654ba; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 16;" prefHeight="50" prefWidth="120" />
                                                     </children>
                                                 </HBox>
                                                 
                                                 <HBox spacing="10" alignment="CENTER_LEFT">
                                                     <children>
                                                         <Label text="Tăng nhanh:" textFill="#707070" style="-fx-font-size: 12;" />
                                                         <Button text="+50k" onAction="#handleAdd50k" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 15; -fx-background-radius: 15; -fx-font-size: 11;" />
                                                         <Button text="+100k" onAction="#handleAdd100k" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 15; -fx-background-radius: 15; -fx-font-size: 11;" />
                                                         <Button text="+500k" onAction="#handleAdd500k" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 15; -fx-background-radius: 15; -fx-font-size: 11;" />
                                                     </children>
                                                 </HBox>

                                                 
                                            </VBox>
                                            
                                            <Separator />
                                            
                                             <VBox spacing="10">
                                                 <Label text="Đấu giá tự động (Auto Bid)" style="-fx-font-weight: bold; -fx-font-size: 16;" />
                                                 
                                                 <!-- State 1: Setup Auto Bid -->
                                                 <VBox fx:id="vboxAutoBidSetup" spacing="10">
                                                     <Label text="Hệ thống sẽ tự động đặt thay bạn. Vui lòng nhập mức giá tối đa (Max Bid)." textFill="#707070" style="-fx-font-size: 12;" />
                                                     <HBox spacing="10">
                                                         <children>
                                                             <TextField fx:id="txtAutoBidMax" prefHeight="50" promptText="Mức giá tối đa..." style="-fx-background-radius: 25; -fx-padding: 0 20; -fx-font-size: 16;" HBox.hgrow="ALWAYS" />
                                                                                                                           <TextField fx:id="txtAutoBidIncrement" prefHeight="50" promptText="Bước giá (min 10k)..." style="-fx-background-radius: 25; -fx-padding: 0 20; -fx-font-size: 16;" prefWidth="150" />
                                                              <Button text="Thiết lập" onAction="#handleSetAutoBid" style="-fx-background-color: #86b817; -fx-text-fill: white; -fx-background-radius: 25; -fx-font-weight: bold; -fx-font-size: 16;" prefHeight="50" prefWidth="120" />
                                                         </children>
                                                     </HBox>
                                                 </VBox>

                                                 <!-- State 2: Auto Bid Active -->
                                                 <VBox fx:id="vboxAutoBidActive" spacing="10" visible="false" managed="false" style="-fx-background-color: #e8f5e9; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #86b817; -fx-border-radius: 10;">
                                                     <HBox alignment="CENTER_LEFT" spacing="15">
                                                         <children>
                                                             <VBox HBox.hgrow="ALWAYS">
                                                                 <Label text="ĐANG KÍCH HOẠT AUTO BID" style="-fx-text-fill: #2e7d32; -fx-font-weight: bold; -fx-font-size: 14;" />
                                                                 <Label fx:id="lblActiveAutoBidMax" text="Tối đa: 0 ₫" style="-fx-font-size: 16;" />
                                                             </VBox>
                                                             <Button text="Hủy" onAction="#handleCancelAutoBid" style="-fx-background-color: #e62117; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" prefHeight="35" prefWidth="80" />
                                                         </children>
                                                     </HBox>
                                                 </VBox>
                                             </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                    
                    <VBox spacing="10" style="-fx-padding: 20 0 0 0;">
                        <Label text="Biểu đồ giá thầu (Realtime)" style="-fx-font-weight: bold; -fx-font-size: 20;" />
                        <LineChart fx:id="priceChart" prefHeight="300" animated="false">
                            <xAxis>
                                <CategoryAxis label="Thời gian" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Mức giá (VNĐ)" autoRanging="true" forceZeroInRange="false" />
                            </yAxis>
                        </LineChart>
                    </VBox>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- PAGE 5: Lịch sử đấu giá (Auction History) -->
            <VBox fx:id="pageHistory" spacing="20.0" style="-fx-padding: 25;" visible="false" managed="false">
                <children>
                    <Label text="Lịch sử đấu giá của bạn" textFill="#191919"><font><Font name="System Bold" size="24.0"/></font></Label>
                    <TableView fx:id="tableHistory" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colHistName" text="Sản phẩm" prefWidth="250" />
                            <TableColumn fx:id="colHistPrice" text="Giá hiện tại" prefWidth="150" />
                            <TableColumn fx:id="colHistBids" text="Số lượt thầu" prefWidth="100" />
                            <TableColumn fx:id="colHistStatus" text="Trạng thái" prefWidth="150" />
                        </columns>
                    </TableView>
                </children>
            </VBox>

            <!-- PAGE 6: Sản phẩm đã thắng (Won Items) -->
            <VBox fx:id="pageWonItems" spacing="20.0" style="-fx-padding: 25;" visible="false" managed="false">
                <children>
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label text="Sản phẩm đã thắng" textFill="#191919"><font><Font name="System Bold" size="24.0"/></font></Label>
                                <Label text="Danh sách các sản phẩm bạn đã đấu giá thành công" textFill="#707070" />
                            </VBox>
                            <Button fx:id="btnPayAllWon" text="THANH TOÁN TẤT CẢ" style="-fx-background-color: #e62117; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;" onAction="#handleQuickPay" />
                        </children>
                    </HBox>
                    <TableView fx:id="tableWon" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colWonName" text="Sản phẩm" prefWidth="250" />
                            <TableColumn fx:id="colWonPrice" text="Giá thắng" prefWidth="150" />
                            <TableColumn fx:id="colWonSeller" text="Người bán" prefWidth="150" />
                            <TableColumn fx:id="colWonDate" text="Ngày kết thúc" prefWidth="180" />
                        </columns>
                    </TableView>
                </children>
            </VBox>
            

        </StackPane>
    </center>

    </BorderPane>

    <!-- Floating Back to Top Button -->
    <Button fx:id="btnBackToTop" visible="false" onAction="#handleBackToTop" text="↑" 
            StackPane.alignment="BOTTOM_RIGHT" 
            style="-fx-background-color: #3665f3; -fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold; -fx-background-radius: 50; -fx-min-width: 50; -fx-min-height: 50; -fx-max-width: 50; -fx-max-height: 50; -fx-translate-x: -30; -fx-translate-y: -30; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);" />
    
    <VBox fx:id="pageMiniCart" StackPane.alignment="TOP_RIGHT" alignment="TOP_RIGHT" managed="false" maxWidth="320.0" onMouseEntered="#handleShowMiniCart" onMouseExited="#handleHideMiniCart" pickOnBounds="false" visible="false">
        <children>
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 0 0 15 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 10); -fx-padding: 20; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 1 1; -fx-border-radius: 0 0 15 15; -fx-translate-x: -130; -fx-translate-y: 60;">
                <children>
                    <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Giỏ hàng của bạn" />
                    <Label style="-fx-font-size: 12; -fx-text-fill: #707070;" text="Sản phẩm bạn đã đấu giá thắng" />
                    <Separator />
                    <VBox fx:id="vboxMiniCartItems" minHeight="50.0" spacing="12.0" />
                    <Separator />
                    <HBox alignment="CENTER_LEFT">
                        <children>
                            <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Tổng thanh toán:" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblMiniCartTotal" style="-fx-font-weight: bold; -fx-font-size: 20;" text="0 ₫" textFill="#e62117" />
                        </children>
                    </HBox>
                    <Button fx:id="btnQuickPay" maxWidth="Infinity" onAction="#handleQuickPay" prefHeight="45.0" style="-fx-background-color: #e62117; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand;" text="THANH TOÁN NGAY" />
                </children>
            </VBox>
        </children>
    </VBox>
</StackPane>