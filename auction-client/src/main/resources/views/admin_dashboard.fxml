<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox prefHeight="600.0" prefWidth="950.0" spacing="0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminDashboardController" style="-fx-background-color: #f0f2f5;">
    <stylesheets>
        <URL value="@/styles/style.css" />
    </stylesheets>
    
    <!-- Top Nav (eBay Style) -->
    <HBox alignment="CENTER_LEFT" prefHeight="65.0" spacing="20.0" style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-width: 0 0 1 0;">
        <padding><Insets left="30" right="30"/></padding>
        <HBox alignment="CENTER_LEFT" spacing="0">
            <Label text="e" textFill="#e53238" style="-fx-font-size: 32; -fx-font-weight: bold;"/>
            <Label text="b" textFill="#0064d2" style="-fx-font-size: 32; -fx-font-weight: bold;"/>
            <Label text="a" textFill="#f5af02" style="-fx-font-size: 32; -fx-font-weight: bold;"/>
            <Label text="y" textFill="#86b817" style="-fx-font-size: 32; -fx-font-weight: bold;"/>
            <Text text=" Bảng Quản Trị" fill="#555555" style="-fx-font-size: 18; -fx-font-weight: normal;">
                <font><Font name="System" size="18.0"/></font>
            </Text>
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Đăng xuất" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #3665f3; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <!-- Sidebar -->
        <VBox prefWidth="260.0" spacing="5.0" fillWidth="true" alignment="TOP_LEFT" style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-width: 0 1 0 0;">
            <padding><Insets top="30" left="15" right="15"/></padding>
            <Button fx:id="btnManageUsers" text="Quản lý người dùng" onAction="#handleSidebarNavigation" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnAuctions" text="Phiên đấu giá" onAction="#handleSidebarNavigation" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnTransactions" text="Giao dịch" onAction="#handleSidebarNavigation" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Button fx:id="btnReports" text="Báo cáo" onAction="#handleSidebarNavigation" maxWidth="Infinity" styleClass="sidebar-button"/>
        </VBox>

        <!-- Main Area -->
        <StackPane fx:id="mainStack" HBox.hgrow="ALWAYS">
            <!-- User Management View -->
            <VBox fx:id="viewManageUsers" spacing="25.0">
                <padding><Insets top="30" left="40" right="40" bottom="30"/></padding>
                
                <HBox alignment="CENTER_LEFT">
                    <Text text="Quản lý người dùng" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-fill: #1c1e21;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="+ Thêm người dùng" onAction="#handleAddUser" style="-fx-background-color: #3665f3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 25; -fx-cursor: hand; -fx-font-size: 14;"/>
                </HBox>

            <!-- Card Container -->
            <VBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 30;">
                <!-- Action Bar -->
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Tìm kiếm người dùng..." prefWidth="300.0" style="-fx-background-radius: 8; -fx-padding: 10 15; -fx-border-color: #e5e5e5; -fx-border-radius: 8; -fx-font-size: 14;"/>
                    <ComboBox fx:id="roleFilter" promptText="Vai trò" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-radius: 8; -fx-font-size: 14;"/>
                    <ComboBox fx:id="statusFilter" promptText="Trạng thái" prefWidth="140.0" style="-fx-background-color: white; -fx-border-color: #e5e5e5; -fx-border-radius: 8; -fx-font-size: 14;"/>
                    <Button text="Tìm kiếm" onAction="#handleSearch" style="-fx-background-color: #0064d2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 25; -fx-cursor: hand; -fx-font-size: 14;"/>
                </HBox>

                <!-- User Table -->
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="usernameCol" text="Tên đăng nhập" prefWidth="180" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="emailCol" text="Email" prefWidth="240" style="-fx-alignment: CENTER-LEFT;"/>
                        <TableColumn fx:id="roleCol" text="Vai trò" prefWidth="130" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="statusCol" text="Trạng thái" prefWidth="150" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="actionCol" text="Thao tác" prefWidth="180" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- Pagination Bar -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Pagination fx:id="pagination" maxPageIndicatorCount="5" pageCount="1" style="-fx-page-information-visible: false;"/>
                </HBox>
            </VBox>
        </VBox>

            <!-- Placeholder Views -->
            <VBox fx:id="viewAuctions" visible="false" managed="false" spacing="25.0">
                <padding><Insets top="30" left="40" right="40" bottom="30"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Text text="Quản lý Phiên đấu giá" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-fill: #1c1e21;"/>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
                <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 30;">
                    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-border-color: #f0f2f5; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                         <Text text="Danh sách phiên đấu giá" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #606770;"/>
                         <Region HBox.hgrow="ALWAYS" />
                         <TextField fx:id="auctionSearchField" promptText="Tìm kiếm sản phẩm..." prefWidth="250" style="-fx-background-color: #f0f2f5; -fx-background-radius: 8; -fx-padding: 8 15;"/>
                    </HBox>
                    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: #f0f2f5; -fx-border-width: 0 1 1 1;">
                        <columns>
                            <TableColumn fx:id="colAuctionId" text="Mã" prefWidth="60"/>
                            <TableColumn fx:id="colItemName" text="Sản phẩm" prefWidth="250"/>
                            <TableColumn fx:id="colAuctionSeller" text="Người bán" prefWidth="150"/>
                            <TableColumn fx:id="colAuctionPrice" text="Giá khởi điểm" prefWidth="120"/>
                            <TableColumn fx:id="colAuctionEndTime" text="Kết thúc" prefWidth="180"/>
                            <TableColumn fx:id="colAuctionAction" text="Thao tác" prefWidth="100"/>
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    </TableView>
                </VBox>
            </VBox>

            <VBox fx:id="viewTransactions" visible="false" managed="false" spacing="25.0">
                <padding><Insets top="30" left="40" right="40" bottom="30"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Text text="Lịch sử Giao dịch" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-fill: #1c1e21;"/>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
                <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 30;">
                    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-border-color: #f0f2f5; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                         <Text text="Lịch sử giao dịch hệ thống" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #606770;"/>
                    </HBox>
                    <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                        <Text text="Tính năng đang được phát triển..." style="-fx-font-size: 18; -fx-fill: #adb5bd;"/>
                    </VBox>
                </VBox>
            </VBox>

            <VBox fx:id="viewReports" visible="false" managed="false" spacing="25.0">
                <padding><Insets top="30" left="40" right="40" bottom="30"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Text text="Báo cáo hệ thống" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-fill: #1c1e21;"/>
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>
                <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 30;">
                    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-border-color: #f0f2f5; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 15 0;">
                         <Text text="Thống kê &amp; Báo cáo" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #606770;"/>
                    </HBox>
                    <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                        <Text text="Tính năng đang được phát triển..." style="-fx-font-size: 18; -fx-fill: #adb5bd;"/>
                    </VBox>
                </VBox>
            </VBox>
        </StackPane>
    </HBox>
</VBox>
