<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="700.0" prefWidth="800.0" style="-fx-background-color: #FFFFFF; -fx-font-family: 'Segoe UI', sans-serif;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AddProductController">
    <children>
        <!-- Tiêu đề cố định ở trên -->
        <VBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-border-color: transparent transparent #e0e0e0 transparent; -fx-padding: 0 40;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <Label text="Complete your listing" textFill="#191919">
                <font><Font name="System Bold" size="28.0" /></font>
            </Label>
        </VBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #FFFFFF;" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
            <content>
                <VBox spacing="40.0" style="-fx-padding: 30 40;">
                    
                    <!-- 1. PHOTOS & VIDEO -->
                    <VBox spacing="12.0">
                        <Label text="PHOTOS &amp; VIDEO *" textFill="#333333">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <VBox spacing="10.0">
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <Button onAction="#handleUploadPhoto" prefHeight="150.0" prefWidth="180.0" style="-fx-background-color: #fcfcfc; -fx-border-color: #d3d3d3; -fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Upload photos/video&#10;or drag and drop" textAlignment="CENTER" textFill="#0654ba">
                                    <font><Font size="13.0"/></font>
                                </Button>
                                <FlowPane fx:id="photoContainer" hgap="10" vgap="10" prefWrapLength="550" />
                            </HBox>
                            <Label text="Accepts .webp, .jpg, .jpeg, .png, .mp4, .mov (Max 10MB)" textFill="#8f8f8f">
                                <font><Font size="12.0" /></font>
                            </Label>
                        </VBox>
                    </VBox>
                    <Separator />

                    <!-- 2. TITLE -->
                    <VBox spacing="12.0">
                        <Label text="TITLE *" textFill="#333333">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <VBox spacing="5.0">
                            <Label text="Item title" textFill="#191919"><font><Font name="System Bold" size="14.0" /></font></Label>
                            <TextField fx:id="txtProductName" prefHeight="45.0" promptText="e.g. iPhone 15 Pro Max 256GB Natural Titanium" style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8;" />
                        </VBox>
                    </VBox>
                    <Separator />

                    <!-- 3. ITEM CATEGORY -->
                    <VBox spacing="12.0">
                        <Label text="ITEM CATEGORY *" textFill="#333333">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <VBox spacing="5.0">
                            <Label text="Store category" textFill="#191919"><font><Font name="System Bold" size="14.0" /></font></Label>
                            <ComboBox fx:id="cboCategory" prefHeight="45.0" prefWidth="300.0" promptText="Select category" style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8;" />
                        </VBox>
                    </VBox>
                    <Separator />

                    <!-- 4. PRICING & DURATION -->
                    <VBox spacing="12.0">
                        <Label text="PRICING &amp; DURATION *" textFill="#333333">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <HBox spacing="25.0">
                            <VBox spacing="5.0">
                                <Label text="Starting Price (VND)" textFill="#191919"><font><Font name="System Bold" size="14.0" /></font></Label>
                                <TextField fx:id="txtStartPrice" prefHeight="45.0" prefWidth="280.0" promptText="e.g. 5,000,000" style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8;" />
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Auction Duration" textFill="#191919"><font><Font name="System Bold" size="14.0" /></font></Label>
                                <HBox alignment="CENTER_LEFT" prefHeight="45.0" style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-color: white; -fx-background-radius: 8;">
                                    <children>
                                        <TextField fx:id="txtDurationValue" prefHeight="43.0" prefWidth="60.0" promptText="7" style="-fx-background-color: transparent; -fx-border-width: 0;" text="7" />
                                        <Separator orientation="VERTICAL" />
                                        <ComboBox fx:id="cboDurationUnit" prefHeight="43.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-border-width: 0; -fx-cursor: hand;" />
                                    </children>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                    <Separator />

                    <!-- 5. DESCRIPTION -->
                    <VBox spacing="12.0">
                        <Label text="DESCRIPTION" textFill="#333333">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                        <TextArea fx:id="txtDescription" prefHeight="180.0" promptText="Describe your item's condition, features, and any important details..." style="-fx-border-color: #cccccc; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;" wrapText="true" />
                    </VBox>
                    
                </VBox>
            </content>
        </ScrollPane>

        <!-- Thanh nút bấm cố định ở dưới -->
        <HBox alignment="CENTER_RIGHT" prefHeight="90.0" spacing="15.0" style="-fx-border-color: #e0e0e0 transparent transparent transparent; -fx-background-color: #FFFFFF; -fx-padding: 0 40;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <Label fx:id="lblStatus" textFill="#ff3b30" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button onAction="#handleCancel" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: transparent; -fx-text-fill: #0654ba; -fx-border-color: #0654ba; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancel" />
            <Button onAction="#handleSaveProduct" prefHeight="45.0" prefWidth="150.0" style="-fx-background-color: #3665f3; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;" text="List item" />
        </HBox>
    </children>
</AnchorPane>